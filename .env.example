# === Privy (https://dashboard.privy.io) ===
# App ID is public and safe to expose to the client.
PRIVY_APP_ID=
# Server-only secret. Never commit, never ship to browser.
PRIVY_APP_SECRET=
# Exposed to the React client for the Privy login widget.
NEXT_PUBLIC_PRIVY_APP_ID=

# === JWT signing (ES256 / P-256) ===
# Base64-encoded PKCS8 PEM. Generate with: npm run keygen
JWT_PRIVATE_KEY=
# Key id, matches `kid` in JWKS. Suggested: key-YYYY-MM.
JWT_KID=
# Public URL of this backend, no trailing slash. Used as `iss`.
JWT_ISSUER=https://auth.claudenomics.com
# Optional audience override. Defaults to "claudenomics".
# JWT_AUDIENCE=claudenomics
# Optional TTL in seconds. Defaults to 3600 (1h).
# JWT_TTL_SECONDS=3600

# === Rotation overlap (optional) ===
# Previous signing key's public part. Kept in JWKS during rotation window (2×TTL).
# JWT_OLD_PUBLIC_KEY=
# JWT_OLD_KID=

# === Opaque-code store (PKCE) ===
# Lifetime of the `code` between /cli-auth redirect and /token exchange.
# CODE_TTL_SECONDS=120

# === Database (Render Postgres) ===
# Use the External Database URL from Render dashboard, with sslmode=require.
DATABASE_URL=postgres://user:pass@host.render.com/db?sslmode=require

# === Receipts (Phase 2) ===
# Comma-separated compose_hash hex values of enclave builds allowed to submit
# receipts. Case-insensitive. Empty = reject all receipts. Required for /receipts
# to accept anything.
ALLOWED_COMPOSE_HASHES=

# === Attestation (Phase 2 - DCAP) ===
# TCB statuses accepted from @phala/dcap-qvl. Comma-separated, case-sensitive.
# Default: UpToDate only (strict). Add SWHardeningNeeded if you've reviewed
# the advisory IDs against your threat model.
# Values: UpToDate | SWHardeningNeeded | ConfigurationNeeded |
#         ConfigurationAndSWHardeningNeeded | OutOfDate |
#         OutOfDateConfigurationNeeded | Revoked | Unknown
TCB_ACCEPTED_STATUSES=UpToDate

# Attestation TTL before enclave must re-register. Default 604800 (7 days).
ATTESTATION_TTL_SECONDS=604800

# === Logging ===
# debug | info | warn | error
LOG_LEVEL=info
