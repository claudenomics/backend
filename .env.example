# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# JWT
JWT_PRIVATE_KEY=
JWT_KID=
JWT_ISSUER=https://auth.claudenomics.com
# JWT_AUDIENCE=claudenomics
# JWT_TTL_SECONDS=3600

# JWT rotation (set both during overlap window)
# JWT_OLD_PUBLIC_KEY=
# JWT_OLD_KID=

# Database
DATABASE_URL=postgres://user:pass@host.render.com/db?sslmode=require
# PG_POOL_MAX=5

# Auth code lifetime + GC
# CODE_TTL_SECONDS=120
# CODE_GC_GRACE_SECONDS=86400

# Rate-limit row GC
# RATE_LIMIT_GC_GRACE_SECONDS=3600

# Receipts / attestation
ALLOWED_COMPOSE_HASHES=
TCB_ACCEPTED_STATUSES=UpToDate
ATTESTATION_TTL_SECONDS=604800

# Loopback callback host allowlist (comma-separated, IP literals only)
# ALLOWED_CALLBACK_HOSTS=127.0.0.1,[::1]

# 1 only behind a trusted edge (Vercel, Render, Cloudflare).
# When 0 (default), per-IP rate limits bucket all traffic together.
TRUST_FORWARDED_FOR=0

# Logging
LOG_LEVEL=info
